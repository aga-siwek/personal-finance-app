# Copy this file to .env and fill in real values. Never commit .env.

# --- Flask ---
FLASK_CONFIG=development
FLASK_APP=wsgi.py

# --- Secrets (change these to strong random values in every environment) ---
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too

# --- Database ---
# Local development defaults to SQLite (zero infrastructure). Switching to
# Postgres later is config-only: just point DATABASE_URL at a postgresql:// URL.
DATABASE_URL=sqlite:///dev.db
# later (Postgres via docker-compose): postgresql://finance_user:finance_password@db:5432/finance_db

# --- Postgres container (docker-compose "db" service; used only when running
#     the Dockerized Postgres path, not for basic local dev) ---
POSTGRES_USER=finance_user
POSTGRES_PASSWORD=finance_password
POSTGRES_DB=finance_db

# --- JWT token lifetimes (seconds) ---
JWT_ACCESS_TOKEN_EXPIRES=900
JWT_REFRESH_TOKEN_EXPIRES=2592000

# --- Uploads ---
UPLOAD_FOLDER=./uploads

# --- CORS (comma-separated origins, or * for all) ---
CORS_ORIGINS=*
