{
  "info": {
    "name": "Personal Finance App API — Stage 2",
    "description": "Auth/User, Categories, Transactions, Budgets, Pots, Recurring Bills, Overview, Admin. Receipt Scanner and the Postgres switch are Stage 3 (not included).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:5000" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "admin_access_token", "value": "" },
    { "key": "category_id", "value": "" },
    { "key": "transaction_id", "value": "" },
    { "key": "budget_id", "value": "" },
    { "key": "pot_id", "value": "" },
    { "key": "recurring_bill_id", "value": "" },
    { "key": "user_id", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/signup",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/auth/logout"
          }
        },
        {
          "name": "Refresh",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{refresh_token}}" }],
            "url": "{{base_url}}/auth/refresh"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get my profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/users/me"
          }
        },
        {
          "name": "Update my profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/users/me",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"New Name\"\n}" }
          }
        },
        {
          "name": "Change password",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/users/me/password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_password\": \"password123\",\n  \"new_password\": \"newpassword123\"\n}"
            }
          }
        },
        {
          "name": "Get settings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/users/me/settings"
          }
        },
        {
          "name": "Update settings",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/users/me/settings",
            "body": { "mode": "raw", "raw": "{\n  \"timezone\": \"Europe/Warsaw\"\n}" }
          }
        },
        {
          "name": "Delete my account",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/users/me"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "List categories",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/categories"
          }
        },
        {
          "name": "Create category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/categories",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Hobbies\"\n}" }
          }
        },
        {
          "name": "Get category",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/categories/{{category_id}}"
          }
        },
        {
          "name": "Update category",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/categories/{{category_id}}",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Hobbies & Crafts\"\n}" }
          }
        },
        {
          "name": "Delete category",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/categories/{{category_id}}"
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "List transactions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/transactions?page=1&per_page=20&sort=latest&search=&category_id=all"
          }
        },
        {
          "name": "Create transaction",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/transactions",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category_id\": {{category_id}},\n  \"recipient_name\": \"Whole Foods\",\n  \"amount\": -4599,\n  \"transaction_date\": \"2026-07-14\"\n}"
            }
          }
        },
        {
          "name": "Get transaction",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/transactions/{{transaction_id}}"
          }
        },
        {
          "name": "Delete transaction (soft delete)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/transactions/{{transaction_id}}"
          }
        }
      ]
    },
    {
      "name": "Budgets",
      "item": [
        {
          "name": "List budgets",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/budgets"
