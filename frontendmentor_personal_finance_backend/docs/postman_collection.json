            "url": "{{base_url}}/budgets/{{budget_id}}",
            "body": { "mode": "raw", "raw": "{\n  \"max_spend\": 60000\n}" }
          }
        },
        {
          "name": "Delete budget",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/budgets/{{budget_id}}"
          }
        }
      ]
    },
    {
      "name": "Pots",
