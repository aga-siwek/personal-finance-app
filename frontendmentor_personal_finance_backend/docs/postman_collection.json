            "url": "{{base_url}}/budgets",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category_id\": {{category_id}},\n  \"max_spend\": 50000,\n  \"theme\": \"green\"\n}"
            }
          }
        },
        {
          "name": "Get budget",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
